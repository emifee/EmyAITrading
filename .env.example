# ─── Broker Configuration ─────────────────────────────────────
# cTrader Open API credentials
# Get these from https://openapi.ctrader.com after creating an application
CTRADER_CLIENT_ID=your_client_id_here
CTRADER_CLIENT_SECRET=your_client_secret_here
CTRADER_ACCESS_TOKEN=your_access_token_here
CTRADER_ACCOUNT_ID=your_account_id_here

# Connection mode (demo or live)
CTRADER_HOST=demo

# ─── AI Configuration ─────────────────────────────────────────
# Claude API from https://console.anthropic.com
ANTHROPIC_API_KEY=your_claude_api_key_here

# ─── Trading Parameters ───────────────────────────────────────
TRADING_SYMBOL=XAUUSD
TRADING_TIMEFRAME=15

# ─── Risk Management ─────────────────────────────────────────
MAX_RISK_PER_TRADE=2.0
MAX_DAILY_LOSS_PCT=6.0
MAX_DRAWDOWN_PCT=15.0
MIN_RR_RATIO=2.0

# ─── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
